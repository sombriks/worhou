// navbar
mixin navbar(localBase=process.env.BASE_URL ?? '')
    nav(class="navbar is-primary" role="navigation"
        aria-label="main navigation")
        div(class="navbar-brand")
            a(class="navbar-item font-weight-bold" href=`${localBase}/`)
                strong WorHou
            a(role="button" class="navbar-burger" aria-label="menu"
                aria-expanded="false" data-target="navbarMenu")
                span(aria-hidden="true")
                span(aria-hidden="true")
                span(aria-hidden="true")
                span(aria-hidden="true")
        div(id="navbarMenu" class="navbar-menu")
            div(class="navbar-start")
                a(class="navbar-item" href=`${localBase}/timelog`) Timelog
                a(class="navbar-item" href=`${localBase}/timesheet`) Timesheet
                a(class="navbar-item" href=`${localBase}/profile`) Profile
                a(class="navbar-item" href=`${localBase}/teams`) Teams
